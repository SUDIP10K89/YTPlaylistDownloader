# Copy this file to .env and adjust as needed.
# .env is read automatically by main.py via python-dotenv.

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ytdlp_downloader
FFMPEG_PATH=./ffmpeg-2026-06-29-git-de6bcf5c05-essentials_build/bin

# Fixes YouTube's "Sign in to confirm you're not a bot" error.
# Path to a cookies.txt file exported from your browser
# (e.g. via the "Get cookies.txt LOCALLY" extension), logged into YouTube.
YTDLP_COOKIES_FILE=./cookies.txt
